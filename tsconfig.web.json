{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "apps/frontend/src/**/*",
    "apps/frontend/src/**/*.tsx",
    "packages/contracts/src/**/*",
    "apps/desktop/src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@api/*": [
        "apps/frontend/src/api/*"
      ],
      "@components/*": [
        "apps/frontend/src/components/*"
      ],
      "@stakload/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@constants/*": [
        "apps/frontend/src/constants/*"
      ],
      "@hooks/*": [
        "apps/frontend/src/hooks/*"
      ],
      "@icons/*": [
        "apps/frontend/src/icons/*"
      ],
      "@platform/*": [
        "apps/frontend/src/platform/*"
      ],
      "@store/*": [
        "apps/frontend/src/store/*"
      ],
      "@util/*": [
        "apps/frontend/src/util/*"
      ]
    }
  }
}
