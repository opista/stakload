{
  "name": "stakload",
  "version": "0.0.1",
  "description": "A unified experience that aggregates all of your favourite game launchers",
  "main": "./out/main/index.js",
  "author": {
    "name": "metacurb",
    "email": "stakload@opista.com",
    "url": "http://opista.com/"
  },
  "homepage": "https://github.com/opista/stakload#readme",
  "bugs": "https://github.com/opista/stakload/issues",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:opista/stakload.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "pnpm lint --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev -w",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "patch-package && node node_modules/electron/install.js && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@apollo/client": "^3.12.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@electron-ipc-bridge/core": "file:electron-ipc-bridge-core-0.0.3.tgz",
    "@electron-toolkit/utils": "^3.0.0",
    "@mantine/carousel": "^7.15.0",
    "@mantine/core": "^7.13.4",
    "@mantine/dates": "^7.13.4",
    "@mantine/form": "^7.13.4",
    "@mantine/hooks": "^7.13.4",
    "@mantine/modals": "^7.13.4",
    "@mantine/notifications": "^7.16.2",
    "@mantine/spotlight": "^7.13.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@noriginmedia/norigin-spatial-navigation": "^2.2.2",
    "@swc/core": "^1.10.12",
    "@tabler/icons-react": "^3.21.0",
    "@tanstack/react-virtual": "^3.11.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/nedb": "^1.8.16",
    "@types/winreg": "^1.2.36",
    "better-sqlite3": "^12.6.0",
    "clsx": "^2.1.1",
    "electron-conf": "^1.2.1",
    "electron-updater": "^6.1.7",
    "embla-carousel-autoplay": "^7.1.0",
    "embla-carousel-react": "^7.1.0",
    "fastq": "^1.17.1",
    "graphql": "^16.10.0",
    "i18next": "^23.16.4",
    "lodash-es": "^4.17.23",
    "mantine-contextmenu": "^7.17.1",
    "nedb-promises": "^6.2.3",
    "patch-package": "^8.0.1",
    "protobufjs": "^7.4.0",
    "react-i18next": "^15.1.0",
    "react-router": "^7.12.0",
    "react-virtualized-auto-sizer": "^1.0.24",
    "react-window": "^1.8.10",
    "reflect-metadata": "^0.2.2",
    "vdf": "^0.0.2",
    "winreg": "^1.2.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron-ipc-bridge/vite-plugin": "file:electron-ipc-bridge-vite-plugin-0.0.3.tgz",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.6.0",
    "electron-devtools-installer": "^3.2.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.26.0",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.0",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^6.4.1",
    "vite-plugin-graphql-loader": "^4.0.4"
  }
}
