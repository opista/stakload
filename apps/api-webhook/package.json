{
  "name": "@stakload/api-webhook",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "start": "node dist/main.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@stakload/database": "workspace:*",
    "@stakload/igdb-vendor": "workspace:*",
    "@stakload/nestjs-logging": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^17.13.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.14",
    "@stakload/eslint-config": "workspace:*",
    "@suites/di.nestjs": "^3.0.1",
    "@suites/doubles.vitest": "^3.0.1",
    "@suites/unit": "^3.0.1",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.0-beta.12",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.3.2",
    "vitest": "^4.0.0-beta.12"
  }
}
