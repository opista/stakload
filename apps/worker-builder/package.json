{
  "name": "@stakload/worker-builder",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "start": "node dist/src/main.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.14",
    "@stakload/nestjs-logging": "workspace:*",
    "@stakload/nestjs-redis": "workspace:*",
    "bullmq": "^5.41.6",
    "joi": "^17.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.14",
    "@stakload/eslint-config": "workspace:*",
    "@suites/di.nestjs": "^3.0.1",
    "@suites/doubles.vitest": "^3.0.1",
    "@suites/unit": "^3.0.1",
    "@swc/core": "^1.15.18",
    "@types/node": "^22.19.1",
    "@vitest/coverage-v8": "^4.0.0-beta.12",
    "rimraf": "^6.0.1",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.2.6",
    "vitest": "^4.0.0-beta.12"
  }
}
