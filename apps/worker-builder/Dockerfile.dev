# Development Dockerfile for worker-builder.
# Single-stage: keeps devDependencies (tsc) available for Tilt
# live_update rebuild commands run inside this container.
FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable

# Install workspace manifests first to maximise layer caching.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.json tsconfig.base.json ./

# Copy only the packages and app this service depends on.
COPY packages/database ./packages/database
COPY packages/nestjs-logging ./packages/nestjs-logging
COPY apps/worker-builder ./apps/worker-builder

# Install ALL dependencies including devDeps (tsc required at runtime
# of the container so live_update's run() can rebuild the app).
RUN pnpm install --frozen-lockfile

# Build shared packages in dependency order, then the app.
RUN pnpm --dir packages/database build
RUN pnpm --dir packages/nestjs-logging build
RUN pnpm --dir apps/worker-builder build

WORKDIR /app/apps/worker-builder

CMD ["node", "dist/src/main.js"]
