{
  "applicationId": "com.opista.trulaunch",
  "version": "1.0.2",
  "defaultMode": "window",
  "documentRoot": "/src/build/",
  "url": "/",
  "enableExtensions": true,
  "enableServer": true,
  "enableNativeAPI": true,
  "singlePageServe": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "app.*",
    "events.*",
    "extensions.*",
    "os.*",
    "process.*",
    "window.*"
  ],
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "modes": {
    "window": {
      "title": "Trulaunch",
      "width": 800,
      "height": 600,
      "minWidth": 800,
      "minHeight": 600,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/public/assets/images/vite.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": false,
      "useSavedState": true,
      "center": true
    }
  },
  "cli": {
    "binaryName": "application",
    "resourcesPath": "/src/build/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "5.4.0",
    "clientVersion": "5.4.0",
    "frontendLibrary": {
      "patchFile": "/src/index.html",
      "devUrl": "http://localhost:3000",
      "projectPath": "/src/",
      "initCommand": "yarn install",
      "devCommand": "yarn vite-dev",
      "buildCommand": "yarn vite-build"
    }
  }
}