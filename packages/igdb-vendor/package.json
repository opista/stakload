{
  "name": "@stakload/igdb-vendor",
  "private": true,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -b tsconfig.build.json --force",
    "clean": "rimraf dist",
    "generate": "pnpm run generate:resources && pnpm run generate:models",
    "generate:models": "node scripts/generate-models.mjs",
    "generate:resources": "node scripts/generate-resources.mjs",
    "update": "pnpm run update-proto && pnpm run generate",
    "update-proto": "node scripts/update-proto.mjs",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json --composite false"
  },
  "devDependencies": {
    "@stakload/eslint-config": "workspace:*",
    "rimraf": "^6.0.1"
  }
}
