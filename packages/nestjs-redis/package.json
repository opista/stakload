{
  "name": "@stakload/nestjs-redis",
  "private": true,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json --composite false"
  },
  "dependencies": {
    "ioredis": "^5.8.1"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.18",
    "@stakload/eslint-config": "workspace:*",
    "@swc/core": "^1.15.18",
    "@vitest/coverage-v8": "^4.0.0-beta.12",
    "rimraf": "^6.0.1",
    "unplugin-swc": "^1.5.9",
    "vite": "^7.3.2",
    "vitest": "^4.0.0-beta.12"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.18"
  }
}
